import sys

from pyspark.sql.functions import (
    col, collect_list, count, desc, explode, explode_outer,
    row_number, coalesce, lit, struct, expr, sum
)
from pyspark.sql.window import Window

from awsglue.utils import getResolvedOptions
from pyspark.context import SparkContext
from awsglue.context import GlueContext
from awsglue.job import Job
from awsglue.dynamicframe import DynamicFrame



##### INIT

args = getResolvedOptions(sys.argv, ["JOB_NAME"])
sc = SparkContext()
glueContext = GlueContext(sc)
spark = glueContext.spark_session

job = Job(glueContext)
job.init(args["JOB_NAME"], args)


#####  PATH

BUCKET = "tedx-2026-data-mp-massigerva2"

tedx_path   = f"s3://{BUCKET}/final_list.csv"
details_path = f"s3://{BUCKET}/details.csv"
tags_path    = f"s3://{BUCKET}/tags.csv"
watch_path   = f"s3://{BUCKET}/related_videos.csv"


##### LOAD DATA
tedx = spark.read.option("header", True).csv(tedx_path)

details = spark.read.option("header", True).csv(details_path)

tags = spark.read.option("header", True).csv(tags_path)

watch = spark.read.option("header", True).csv(watch_path)


##### DETAILS JOIN

details_clean = details.select(
    col("id").alias("id_ref"),
    col("description"),
    col("duration"),
    col("publishedAt"),
    col("interalId")  # mantenuto per mapping
)

tedx_main = tedx.join(
    details_clean,
    tedx.id == details_clean.id_ref,
    "left"
).drop("id_ref")



##### TAGS AGGREGATION
tags_agg = tags.groupBy("id") \
    .agg(collect_list("tag").alias("tags"))

tedx_full = tedx_main.join(
    tags_agg,
    tedx_main.id == tags_agg.id,
    "left"
).drop(tags_agg.id)



##### WATCH NEXT BASE (original signal)

internal_map = details.select(
    col("interalId").alias("internal"),
    col("id").alias("public_id")
)

watch_resolved = watch.join(
    internal_map,
    watch.related_id == internal_map.internal,
    "left"
).select(
    col("id").alias("source_id"),
    col("public_id").alias("target_id"),
    col("viewedCount").cast("long").alias("views")
).filter(col("target_id").isNotNull())


w = Window.partitionBy("source_id").orderBy(desc("views"))

watch_ranked = watch_resolved.withColumn(
    "rn",
    row_number().over(w)
)

watch_original = watch_ranked.filter(col("rn") <= 10) \
    .groupBy("source_id") \
    .agg(collect_list("target_id").alias("watch_next_original"))



##### EMOTION MAP


